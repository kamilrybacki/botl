#!/bin/sh
# Pre-commit hook: mirrors CI quality gate (Go Report Card checks)
# Install: git config core.hooksPath .githooks
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

fail() {
    printf "${RED}${BOLD}✗ %s${NC}\n" "$1"
    exit 1
}

pass() {
    printf "${GREEN}✓${NC} %s\n" "$1"
}

require_tool() {
    TOOL_NAME="$1"
    INSTALL_CMD="$2"
    if command -v "$TOOL_NAME" >/dev/null 2>&1; then
        return 0
    elif [ -x "$(go env GOPATH)/bin/$TOOL_NAME" ]; then
        return 0
    fi
    printf "\n${RED}${BOLD}MISSING REQUIRED TOOL: %s${NC}\n" "$TOOL_NAME"
    printf "Install it now:\n\n"
    printf "  ${BOLD}%s${NC}\n\n" "$INSTALL_CMD"
    printf "Then re-run your commit.\n"
    exit 1
}

resolve_tool() {
    TOOL_NAME="$1"
    if command -v "$TOOL_NAME" >/dev/null 2>&1; then
        echo "$TOOL_NAME"
    else
        echo "$(go env GOPATH)/bin/$TOOL_NAME"
    fi
}

printf "Running pre-commit quality checks...\n"

# Check all required tools are present before running any checks
require_tool "gocyclo" "go install github.com/fzipp/gocyclo/cmd/gocyclo@latest"
require_tool "ineffassign" "go install github.com/gordonklaus/ineffassign@latest"
require_tool "misspell" "go install github.com/client9/misspell/cmd/misspell@latest"

# 1. gofmt -s
unformatted=$(gofmt -s -l . 2>&1 || true)
if [ -n "$unformatted" ]; then
    printf "${RED}Files not formatted with gofmt -s:${NC}\n"
    echo "$unformatted"
    printf "Run: gofmt -s -w .\n"
    fail "gofmt -s"
fi
pass "gofmt -s"

# 2. go vet
if ! go vet ./... 2>&1; then
    fail "go vet"
fi
pass "go vet"

# 3. gocyclo (complexity > 15)
GOCYCLO=$(resolve_tool gocyclo)
result=$($GOCYCLO -over 15 . 2>&1 || true)
if [ -n "$result" ]; then
    printf "${RED}Functions with cyclomatic complexity > 15:${NC}\n"
    echo "$result"
    fail "gocyclo"
fi
pass "gocyclo"

# 4. ineffassign
INEFFASSIGN=$(resolve_tool ineffassign)
if ! $INEFFASSIGN ./... 2>&1; then
    fail "ineffassign"
fi
pass "ineffassign"

# 5. misspell
MISSPELL=$(resolve_tool misspell)
result=$($MISSPELL -error . 2>&1 || true)
if [ -n "$result" ]; then
    printf "${RED}Misspellings found:${NC}\n"
    echo "$result"
    fail "misspell"
fi
pass "misspell"

printf "${GREEN}${BOLD}All checks passed.${NC}\n"
